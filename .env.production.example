# .env.production.example — copier en .env.production sur le VPS
# ATTENTION : ce fichier est dans le repo, .env.production NE doit PAS l'être (gitignore)

NODE_ENV=production

# MongoDB
MONGO_USER=sallycards
MONGO_PASSWORD=CHANGE_ME_RUN_openssl_rand_hex_32
MONGO_DB=sallycards

# JWT - généré avec `openssl rand -hex 64`
JWT_SECRET=CHANGE_ME_RUN_openssl_rand_hex_64
JWT_REFRESH_SECRET=CHANGE_ME_RUN_openssl_rand_hex_64
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS - origines autorisées (séparées par virgule)
CORS_ORIGINS=https://sallycards.salistar.com,https://salistar.com,https://backoffice.salistar.com

# URLs publiques (utilisées par le web Next.js)
NEXT_PUBLIC_API_URL=https://api.salistar.com/api/v1
NEXT_PUBLIC_SOCKET_URL=https://ws.salistar.com

# Ports internes (ne pas changer)
API_PORT=3000
SOCKET_PORT=3001
WEB_PORT=4000

# ─── TURN / STUN (WebRTC multijoueur voix/vidéo) ───────────────────────
# Le secret DOIT être identique à `static-auth-secret` dans docker/turnserver.conf.
# L'endpoint /api/v1/api/turn-creds génère des credentials HMAC tournants (24h).
TURN_HOST=turn.salistar.com
TURN_PORT=3478
TURN_TLS_PORT=5349
TURN_SECRET=change_me_long_random_shared_with_coturn

# ─── Météo (challenges sport en extérieur) ─────────────────────────────
# Optionnel : sans clé, l'API renvoie une météo mock déterministe.
OPENWEATHER_API_KEY=
