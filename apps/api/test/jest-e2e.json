{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@sally/types$": "<rootDir>/../../libs/shared/types/src/index.ts",
    "^@sally/(.*)$": "<rootDir>/../../libs/$1/src/index.ts"
  }
}
